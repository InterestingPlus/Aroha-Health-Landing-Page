---
import Container from "./Container.astro";
import SectionHeading from "./SectionHeading.astro";

const days = ["Mon 12", "Tue 13", "Wed 14", "Thu 15", "Fri 16"];
const lines = [1, 2, 3, 4];
const cols = [0, 1, 2, 3, 4];
---

<section class="py-24 bg-white overflow-hidden">
  <Container>
    <SectionHeading
      title="Everything in One Clear Dashboard"
      subtitle="Stay on top of appointments, sessions, and client activity from a single intuitive dashboard designed for healthcare professionals."
    />

    <div class="relative mt-16 max-w-5xl mx-auto">
      <div
        class="bg-white border border-slate-200 rounded-2xl shadow-2xl overflow-hidden flex aspect-[4/3] md:aspect-[16/9]"
      >
        <!-- Sidebar -->
        <div
          class="hidden md:flex flex-col w-64 bg-slate-50 border-r border-slate-200 p-4"
        >
          <div class="flex items-center gap-2 mb-8 px-2">
            <div class="bg-white rounded-lg">
              <img
                src="https://aroha-health.com/assets/logo.png"
                alt="Aroha Health Logo"
                width="40"
                height="40"
              />
            </div>
            <span class="font-bold text-slate-800">Aroha Health</span>
          </div>

          <div class="space-y-1">
            <!-- Calendar -->
            <div
              class="flex items-center gap-3 px-3 py-2 bg-purple-100 text-purple-700 rounded-lg font-medium relative group"
            >
              <!-- icon -->
              <span>Calendar</span>

              <div
                class="absolute -left-12 top-1/2 -translate-y-1/2 bg-purple-600 text-white text-xs px-2 py-1 rounded shadow-lg whitespace-nowrap hidden group-hover:block z-20"
              >
                <div
                  class="absolute right-[-4px] top-1/2 -translate-y-1/2 w-2 h-2 bg-purple-600 rotate-45"
                >
                </div>
                Calendar View
              </div>
            </div>

            <!-- Clients -->
            <div
              class="flex items-center gap-3 px-3 py-2 text-slate-600 hover:bg-slate-100 rounded-lg font-medium relative group cursor-pointer transition-colors"
            >
              <!-- icon -->
              <span>Clients</span>

              <div
                class="absolute -left-12 top-1/2 -translate-y-1/2 bg-teal-600 text-white text-xs px-2 py-1 rounded shadow-lg whitespace-nowrap hidden group-hover:block z-20"
              >
                <div
                  class="absolute right-[-4px] top-1/2 -translate-y-1/2 w-2 h-2 bg-teal-600 rotate-45"
                >
                </div>
                Client List
              </div>
            </div>

            <!-- Sessions -->
            <div
              class="flex items-center gap-3 px-3 py-2 text-slate-600 hover:bg-slate-100 rounded-lg font-medium relative group cursor-pointer transition-colors"
            >
              <!-- icon -->
              <span>Sessions & Notes</span>

              <div
                class="absolute -left-12 top-1/2 -translate-y-1/2 bg-sky-600 text-white text-xs px-2 py-1 rounded shadow-lg whitespace-nowrap hidden group-hover:block z-20"
              >
                <div
                  class="absolute right-[-4px] top-1/2 -translate-y-1/2 w-2 h-2 bg-sky-600 rotate-45"
                >
                </div>
                Sessions
              </div>
            </div>
          </div>
        </div>

        <!-- Main Area -->
        <div class="flex-1 flex flex-col bg-white relative">
          <!-- Header -->
          <div
            class="h-16 border-b border-slate-100 flex justify-between items-center px-6"
          >
            <h3 class="font-semibold text-lg text-slate-800">
              Weekly Schedule
            </h3>

            <div class="flex items-center gap-3">
              <div class="bg-slate-100 p-2 rounded-full">
                <!-- search icon -->
              </div>

              <button
                class="bg-purple-600 text-white px-4 py-2 rounded-lg text-sm font-medium relative group"
              >
                + Create

                <div
                  class="absolute -top-10 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-xs px-2 py-1 rounded shadow-lg whitespace-nowrap hidden group-hover:block z-20"
                >
                  <div
                    class="absolute bottom-[-4px] left-1/2 -translate-x-1/2 w-2 h-2 bg-slate-800 rotate-45"
                  >
                  </div>
                  New Appointments
                </div>
              </button>
            </div>
          </div>

          <!-- Calendar -->
          <div class="flex-1 p-6 bg-slate-50/50">
            <div
              class="bg-white border border-slate-200 rounded-xl h-full shadow-sm flex flex-col"
            >
              <!-- Days header -->
              <div class="grid grid-cols-5 border-b border-slate-200">
                {
                  days.map((day, i) => (
                    <div
                      class={`p-3 text-center text-sm font-medium ${
                        i === 1
                          ? "text-purple-600 border-b-2 border-purple-600"
                          : "text-slate-500"
                      } border-r border-slate-100 last:border-0`}
                    >
                      {day}
                    </div>
                  ))
                }
              </div>

              <!-- Calendar body -->
              <div class="flex-1 grid grid-cols-5 relative">
                <!-- horizontal lines -->
                <div
                  class="absolute inset-0 flex flex-col justify-between pointer-events-none opacity-20"
                >
                  {
                    lines.map(() => (
                      <div class="w-full border-t border-slate-300 flex-1" />
                    ))
                  }
                </div>

                <!-- columns -->
                {
                  cols.map((col) => (
                    <div class="border-r border-slate-100 last:border-0 relative p-2">
                      {col === 1 && (
                        <div class="absolute top-10 left-2 right-2 bg-purple-100 border border-purple-200 rounded-md p-2 shadow-sm">
                          <p class="text-xs font-semibold text-purple-900">
                            Dr. Smith Consult
                          </p>
                          <p class="text-[10px] text-purple-700 mt-1">
                            10:00 - 11:00 AM
                          </p>
                        </div>
                      )}

                      {col === 3 && (
                        <div class="absolute top-32 left-2 right-2 bg-teal-100 border border-teal-200 rounded-md p-2 shadow-sm">
                          <p class="text-xs font-semibold text-teal-900">
                            Therapy: Client A
                          </p>
                          <p class="text-[10px] text-teal-700 mt-1">
                            01:00 - 02:00 PM
                          </p>
                        </div>
                      )}
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- decorative blobs -->
      <div
        class="absolute -top-10 -right-10 w-40 h-40 bg-teal-400 rounded-full mix-blend-multiply blur-3xl opacity-20"
      >
      </div>
      <div
        class="absolute -bottom-10 -left-10 w-40 h-40 bg-purple-400 rounded-full mix-blend-multiply blur-3xl opacity-20"
      >
      </div>
    </div>
  </Container>
</section>
