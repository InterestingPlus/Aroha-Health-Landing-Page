---
import Container from "./Container.astro";
import SectionHeading from "./SectionHeading.astro";

const capabilities = [
  {
    icon: "fa-regular fa-clock",
    title: "Save Time",
    desc: "Automate appointment scheduling and reminders so you can focus more on client care.",
  },
  {
    icon: "fa-regular fa-folder",
    title: "Stay Organized",
    desc: "Keep client records, session notes, and appointments neatly organized in one place.",
  },
  {
    icon: "fa-regular fa-chart-area",
    title: "Reduce No-Shows",
    desc: "Automated reminders and confirmations help reduce missed appointments and cancellations.",
  },
];
---

<section class="py-24 bg-lightBg border-y border-gray-100">
  <Container>
    <SectionHeading
      title="Why Professionals Love Aroha Scheduling"
      subtitle="Everything you need to simplify scheduling and client management."
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
      {
        capabilities.map((cap) => (
          <div class="flex gap-4 items-start">
            <div class="bg-white p-3 rounded-xl shadow-sm border border-gray-200 text-primary shrink-0">
              <i class={cap.icon} />
            </div>

            <div>
              <h4 class="text-lg font-bold text-darkBlue mb-2">{cap.title}</h4>

              <p class="text-textGray leading-relaxed text-sm">{cap.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
