---
import Container from "./Container.astro";
---

<footer class="py-12 bg-darkerBlue text-white">
  <Container>
    <div class="flex flex-col md:flex-row justify-between gap-10">
      <div class="flex flex-col">
        <h1 class="text-[40px] font-bold">Aroha</h1>
        <h3 class="text-[20px]">Your Practice, Your Way</h3>
      </div>

      <div class="flex flex-col">
        <h3 class="text-[22px] font-semibold">Follow us</h3>

        <ul class="flex gap-3 text-[30px] mt-2">
          <li>
            <a
              href="https://www.linkedin.com/company/arohahealth/"
              class="hover:text-primary transition"
            >
              <i class="fa-brands fa-linkedin"></i>
            </a>
          </li>

          <li>
            <a
              href="https://x.com/Aroha_health"
              class="hover:text-primary transition"
            >
              <i class="fa-brands fa-x-twitter"></i>
            </a>
          </li>

          <li>
            <a
              href="https://www.instagram.com/arohahealthofficial"
              class="hover:text-primary transition"
            >
              <i class="fa-brands fa-instagram"></i>
            </a>
          </li>
        </ul>

        <ul class="flex gap-4 mt-3 text-sm text-gray-300">
          <li>
            <a href="" class="hover:text-white transition">
              Terms & Conditions
            </a>
          </li>
          <li>
            <a href="" class="hover:text-white transition"> Privacy Policy </a>
          </li>
        </ul>
      </div>
    </div>

    <p class="text-[13px] text-gray-400 mt-10">
      &copy; {Number(new Date().getFullYear()) - 1}-{new Date().getFullYear()}
      Aroha · All rights reserved.
    </p>
  </Container>
</footer>
