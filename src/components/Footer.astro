---
import Container from "./Container.astro";
---

<footer class="bg-slate-50 py-12 border-t border-slate-200">
  <Container>
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <div class="bg-white text-white rounded-lg">
          <img
            src="https://aroha-health.com/assets/logo.png"
            alt="Aroha Health Logo"
            width="40"
            height="40"
          />
        </div>

        <span class="font-bold text-lg text-slate-900"> Aroha Health </span>
      </div>

      <!-- Links -->
      <div class="flex gap-6 text-sm text-slate-500">
        <a
          href="/privacy-policy"
          class="transition-colors hover:text-purple-600"
        >
          Privacy Policy
        </a>

        <a
          href="/terms-of-service"
          class="transition-colors hover:text-purple-600"
        >
          Terms of Service
        </a>

        <a
          href="/contact-support"
          class="transition-colors hover:text-purple-600"
        >
          Contact Support
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-sm text-slate-400">
        © 2026 Aroha Health. All rights reserved.
      </p>
    </div>
  </Container>
</footer>
